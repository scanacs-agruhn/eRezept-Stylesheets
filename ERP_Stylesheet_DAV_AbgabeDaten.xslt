<?xml version="1.0" encoding="UTF-8"?><xsl:stylesheet version="1.0"                xmlns:xsl="http://www.w3.org/1999/XSL/Transform"                xmlns:fhir="http://hl7.org/fhir"                xmlns:xhtml="http://www.w3.org/1999/xhtml"                xmlns="http://www.w3.org/1999/xhtml"                exclude-result-prefixes="fhir xhtml">    <!-- Ersteller: (ABDA/DAV) fhir@abda.de -->    <xsl:param name="anonymize" select="'false'"/>    <xsl:output method="html" encoding="UTF-8" indent="yes" omit-xml-declaration="yes"/>    <xsl:template match="/">        <xsl:text disable-output-escaping='yes'>&lt;!DOCTYPE html&gt;</xsl:text>        <html lang="de">            <head>                <meta charset="UTF-8"/>                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>                <meta name="author" content="ABDA/DAV"/>                <link rel="icon" type="image/png" href="data:image/png;base64,"/>                <style>                    <xsl:text disable-output-escaping='yes'>                        @charset "UTF-8";                        /* Minimales optimiertes Bootstrap Grid System v5.3.0 (https://getbootstrap.com/)                        * Copyright 2011-2023 The Bootstrap Authors                        * Licensed under MIT (https://github.com/twbs/bootstrap/blob/main/LICENSE) */                        :root {                            --bs-body-font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;                            --bs-body-font-size: 1rem;                            --bs-body-font-weight: 400;                            --bs-body-line-height: 1.5;                            --bs-body-color: #212529;                            --bs-body-bg: #fff;                            --bs-heading-color: inherit;                            --bs-border-width: 1px;                        }                        *,                        ::after,                        ::before {                            box-sizing: border-box;                        }                        body {                            margin: 0;                            font-family: var(--bs-body-font-family);                            font-size: var(--bs-body-font-size);                            font-weight: var(--bs-body-font-weight);                            line-height: var(--bs-body-line-height);                            color: var(--bs-body-color);                            background-color: var(--bs-body-bg);                            -webkit-text-size-adjust: 100%;                            -webkit-tap-highlight-color: transparent;                        }                        hr {                            margin: 1rem 0;                            color: inherit;                            border: 0;                            border-top: var(--bs-border-width) solid;                            opacity: .25;                        }                        h1, h4 {                            margin-top: 0;                            margin-bottom: .5rem;                            font-weight: 500;                            line-height: var(--bs-body-line-height);                        }                        h1 {                            font-size: calc(1.375rem + 1.5vw);                        }                        @media (min-width:1200px) {                            h1 {                                font-size: 2.5rem;                            }                        }                        h4 {                            font-size: calc(1.275rem + .3vw);                        }                        @media (min-width:1200px) {                            h4 {                                font-size: 1.5rem;                            }                        }                        label {                            display: inline-block;                        }                        input,                        textarea {                            margin: 0;                            font-family: inherit;                            font-size: inherit;                            line-height: inherit;                        }                        textarea {                            resize: vertical;                        }                        .row {                            --bs-gutter-x: 1.5rem;                            --bs-gutter-y: 0;                            display: flex;                            flex-wrap: wrap;                            margin-top: calc(-1 * var(--bs-gutter-y));                            margin-right: calc(-.5 * var(--bs-gutter-x));                            margin-left: calc(-.5 * var(--bs-gutter-x));                        }                        .row>* {                            flex-shrink: 0;                            width: 100%;                            max-width: 100%;                            padding-right: calc(var(--bs-gutter-x) * .5);                            padding-left: calc(var(--bs-gutter-x) * .5);                            margin-top: var(--bs-gutter-y);                        }                        .col {                            flex: 1 0 0%;                        }                        .col-1 {                            flex: 0 0 auto;                            width: 8.33333333%;                        }                        .col-2 {                            flex: 0 0 auto;                            width: 16.66666667%;                        }                        .col-3 {                            flex: 0 0 auto;                            width: 25%;                        }                        .col-4 {                            flex: 0 0 auto;                            width: 33.33333333%                        }                        .col-5 {                            flex: 0 0 auto;                            width: 41.66666667%                        }                        .col-6 {                            flex: 0 0 auto;                            width: 50%;                        }                        .col-8 {                            flex: 0 0 auto;                            width: 66.66666667%;                        }                        .col-9 {                            flex: 0 0 auto;                            width: 75%;                        }                        .col-10 {                            flex: 0 0 auto;                            width: 83.33333333%;                        }                        .col-12 {                            flex: 0 0 auto;                            width: 100%;                        }                        .g-0 {                            --bs-gutter-x: 0;                            --bs-gutter-y: 0;                        }                        .g-1 {                            --bs-gutter-x: 0.25rem;                            --bs-gutter-y: 0.25rem;                        }                        .g-2 {                            --bs-gutter-x: 0.5rem;                            --bs-gutter-y: 0.5rem;                        }                        @media (min-width:768px) {                            .col-md-6 {                                flex: 0 0 auto;                                width: 50%;                            }                        }                        .border-1 {                            border-width: 1px !important;                        }                        /* Bootstrap Ende */                    </xsl:text>                </style>                <style>                    <xsl:text disable-output-escaping='yes'>                    /* Internes Stylesheet */                    /* Globale Variablen */                    :root{                        --background-color-ges: #ffffff;                        --border-background-color-ges: #d8c5ff; /* #F7B8CA; */                        --text-color-ges: #9f6dff; /* #bf5473; */                        --text-color-inputs: #000000;                        --background-stripes-color: #e9e9e9;                        --outter-div-bg-color: #F7B8CA;                        --background-color-int: var(--border-background-color-ges);                        --border-background-color-int: var(--border-background-color-ges);                    }                    body {                        width: 210mm;                        max-width: 210mm;                        min-width: 210mm;                        left:0;                        top: 0;                        margin: 0px;                        padding: 5mm;                        font-size: 12px;                        font-family: Arial, sans-serif;                        /*                        background: repeating-linear-gradient(                            135deg,                            var(--background-stripes-color),                            var(--background-stripes-color) 10px,                            transparent 10px,                            transparent 20px                        );                        */                    }                    .background-container-ges{                        background-color: var(--background-color-ges);                        border: 1px solid var(--border-background-color-ges);                        /*                        color: var(--text-color-ges);                        */                    }                    h1 {                        font-size: large;                        font-weight: bold;                    }                    h4 {                        margin-top: 2mm;                        color:var(--text-color-ges);                        font-size: medium;                        font-weight: bold;                        padding-bottom: 0px;                        margin-bottom: 0px;                    }                    input {                        border: 1px solid #c3c3c3;                        outline: none;                    }                    .input-container {                        position: relative;                        width: 100%;                    }                    .input-container label {                        position: absolute;                        top: -0px;                        left: 0px;                        padding: 0 5px;                        font-size: 10px;                        color: var(--text-color-ges);                        z-index: 1;                    }                    .text-input, .hzp{                        font-family: Consolas, sans-serif;                        height: 10mm;                        width: 100%;                        text-align: left;                        border: 1px solid var(--text-color-ges);                        box-shadow: none;                        appearance: none;                        outline: none;                        background-color: var(--background-color-ges);                        padding-top: 14px;                        padding-left: 10px;                        color: var(--text-color-inputs);                    }                    /* Textarea mit dynamischer Höhenanpassung */                    textarea.text-input {                        font-family: Consolas, sans-serif;                        height: auto;                        text-align: left;                        border: 1px solid var(--text-color-ges);                        box-shadow: none;                        appearance: none;                        outline: none;                        background-color: var(--background-color-ges);                        padding-top: 14px;                        padding-left: 10px;                        color: var(--text-color-inputs);                        min-height: 10mm;                        max-height: none;                        resize: vertical;                        overflow-y: auto;                        outline: none;                        field-sizing: content;                        line-height: var(--bs-body-line-height);                    }                    textarea.text-input-fix {                        font-family: Consolas, sans-serif;                        width: 100%;                        text-align: left;                        border: 1px solid var(--text-color-ges);                        box-shadow: none;                        appearance: none;                        outline: none;                        background-color: var(--background-color-ges);                        padding-top: 14px;                        padding-left: 10px;                        color: var(--text-color-inputs);                        min-height: 10mm;                        max-height: none;                        resize: vertical;                        overflow-y: auto;                        outline: none;                        field-sizing: content;                        line-height: var(--bs-body-line-height);                    }                    .text-input div{                        margin-left: 2px;                    }                    [data-tooltip] {                      position: relative;                      cursor: pointer;                    }                    [data-tooltip]::after {                      content: attr(data-tooltip);                      position: absolute;                      /* Tooltip Styling */                      background-color: var(--background-color-ges);                      color: var(--text-color-ges);                      padding: 5px;                      border-radius: 4px;                      z-index: 500;                      /* Verstecken */                      opacity: 0;                      visibility: hidden;                      transition: opacity 0.3s;                    }                    [data-tooltip]:hover::after {                      opacity: 1;                      visibility: visible;                    }                    .intern-container{                        background-color: var(--background-color-int);                        padding:2mm;                    }                    .row{                        padding-top: 0px;                        padding-bottom: 3px;                    }                    hr{                        margin-top: 1mm;                        margin-bottom: 1mm;                        background-color: var(--text-color-ges);                    }                    .col, .col-*, .row {                        flex: none !important;                        width: auto !important;                    }                    .outter-div {                        background-color: var(--outter-div-bg-color);                        overflow: hidden;                        width: 210mm;                        max-width: 210mm;                        min-width: 210mm;                        padding:5mm;                    }                    .row .col-1-5{                        flex: 0 0 auto;                        width: 12.49%;                    }                    .row .col-2-5{                        flex: 0 0 auto;                        width: 20.8333333333333%;                    }                    .row .col-5-5{                        flex: 0 0 auto;                        width: 45.8333333333333%;                    }                    @media print {                        @page {                            size: A4;                            margin: 0;                        }                        body {                            margin: 0;                            padding: 0;                        }                    }                    .width-100{ width: 100%; }                    .padding-1{ padding: 0.5%; }                    .height-12mm{ height: 12mm; }                    .height-15mm{ height: 15mm; }                    .height-25mm{ height: 25mm; }                    .padding-bot-2{ padding-bottom: 2mm; }                    .vertical-align{ margin-top: 10px; }                    .padding-top-bot-0{ padding-top: 0px; padding-bottom: 0px; }                    .margin-top-minus-6px{ margin-top: -6px; }                    .margin-left-min-2{ margin-left: -2px; }                    .margin-right-min-2{ margin-right: -2px; }                    .margin-top-min-5{ margin-top: -5px; }                    .margin-top-min-6{ margin-top: -6px; }                    .margin-top-5{ margin-top: 5px; }                    /* Zusatzattribute Tabelle */                    .zusatz-attributes-table {                        width: 100%;                        border-collapse: collapse;                        border: 1px solid var(--text-color-ges);                        font-size: 10px;                        margin-top: 4px;                        background-color: var(--background-color-ges);                    }                    .zusatz-attributes-table thead {                        background-color: var(--background-color-ges);                    }                    .zusatz-attributes-table th {                        border: 1px solid var(--text-color-ges);                        padding: 4px 6px;                        text-align: left;                        font-weight: bold;                        color: var(--text-color-ges);                        background-color: var(--background-color-ges);                    }                    .zusatz-attributes-table td {                        border: 1px solid var(--text-color-ges);                        padding: 3px 6px;                        text-align: left;                        background-color: var(--background-color-ges);                    }                    .zusatz-attributes-table tbody tr:nth-child(odd) {                        background-color: transparent;                    }                    /* Dokumentationszeilen in Zusatzattribute-Tabelle */                    .zusatz-doc-row {                        background-color: transparent;                    }                    .zusatz-doc-row td {                        padding-left: 4.5em !important;                        color: #555;                        font-style: italic;                        padding-top: 2px !important;                        padding-bottom: 2px !important;                        background-color: var(--background-color-ges);                    }                    /* Internes Stylesheet Ende */                    </xsl:text>                </style>                <title>DAV Stylesheet Abgabedaten</title>            </head>            <body>                <xsl:choose>                    <xsl:when test="not(fhir:Bundle)">                        <b>ERP Stylesheet Abgabedaten</b>                        <b>Instanz ist kein Bundle</b>                        <br/>                    </xsl:when>                    <xsl:when test="fhir:Bundle">                        <xsl:choose>                            <xsl:when test="fhir:Bundle/fhir:meta/fhir:profile/@value = 'http://fhir.abda.de/eRezeptAbgabedaten/StructureDefinition/DAV-PR-ERP-AbgabedatenBundle|1.1.0'">                                <xsl:apply-templates select="fhir:Bundle"/>                            </xsl:when>                            <xsl:when test="fhir:Bundle/fhir:meta/fhir:profile/@value = 'http://fhir.abda.de/eRezeptAbgabedaten/StructureDefinition/DAV-PR-ERP-AbgabedatenBundle|1.3'">                                <xsl:apply-templates select="fhir:Bundle"/>                            </xsl:when>                            <xsl:when test="fhir:Bundle/fhir:meta/fhir:profile/@value = 'http://fhir.abda.de/eRezeptAbgabedaten/StructureDefinition/DAV-PR-ERP-AbgabedatenBundle|1.4'">                                <xsl:apply-templates select="fhir:Bundle"/>                            </xsl:when>                            <xsl:when test="fhir:Bundle/fhir:meta/fhir:profile/@value = 'http://fhir.abda.de/eRezeptAbgabedaten/StructureDefinition/DAV-PR-ERP-AbgabedatenBundle|1.5'">                                <xsl:apply-templates select="fhir:Bundle"/>                            </xsl:when>                            <xsl:otherwise>                                <b>ERP Stylesheet Abgabedaten</b>                                <br/>                                <b>!!! Profile-Version stimmt nicht bzw. wird nicht unterstützt!!!</b>                                <br/>                                Profile+Version: "<xsl:value-of select="fhir:Bundle/fhir:meta/fhir:profile/@value"/>"                            </xsl:otherwise>                        </xsl:choose>                    </xsl:when>                </xsl:choose>            </body>        </html>    </xsl:template>    <xsl:template match="fhir:Bundle[not(ancestor::fhir:Bundle)]">        <xsl:variable name="_rowId">            <xsl:call-template name="getIdFromReference">                <xsl:with-param name="ref" select="/fhir:Bundle/fhir:entry/fhir:resource/fhir:MedicationDispense[fhir:type/fhir:coding/fhir:code/@value='Abgabeinformationen']/fhir:extension[@url='http://fhir.abda.de/eRezeptAbgabedaten/StructureDefinition/DAV-EX-ERP-Abrechnungszeilen']/fhir:valueReference/fhir:reference/@value"/>            </xsl:call-template>        </xsl:variable> <!--xsl:value-of select="($rowId)"/-->        <div class="background-container-ges outter-div">            <xsl:choose>                <xsl:when test="$anonymize='true'">                    <h1>Abgabedatensatz (anonymisierte Ausgabe)</h1>                    <!--xsl:value-of select="if ($anonymize='true') then 'anonymisiert' else 'Originalwert'"/  leider erst ab XSLT 2.0+ -->                </xsl:when>                <xsl:otherwise>                    <!-- normale Ausgabe -->                    <h1>Abgabedatensatz</h1>                </xsl:otherwise>            </xsl:choose>            <div class="row g-1 intern-container">                <div class="col-md-1 border-1">                    <div class="row g-1">                        <div class="col-3">                            <div class="input-container">                                <label>Rezept ID</label>                                <div class="text-input">                                    <xsl:value-of select="//fhir:Bundle/fhir:identifier/fhir:value/@value"/>                                </div>                            </div>                        </div>                        <div class="col-3">                            <div class="input-container">                                <label>Abgabedatum</label>                                <div class="text-input">                                    <xsl:call-template name="formatDate">                                        <xsl:with-param name="date" select="fhir:entry/fhir:resource/fhir:MedicationDispense[fhir:type/fhir:coding/fhir:code/@value='Abgabeinformationen']/fhir:whenHandedOver/@value"/>                                    </xsl:call-template>                                </div>                            </div>                        </div>                        <div class="col-3">                            <div class="input-container">                                <label>Gesamtbetrag</label>                                <div class="text-input">                                    <xsl:value-of select="translate(/fhir:Bundle/fhir:entry/fhir:resource/fhir:Invoice[fhir:id/@value=$_rowId]/fhir:totalGross/fhir:value/@value, '.', ',')"/>                                    <xsl:text disable-output-escaping='yes'> </xsl:text>                                    <xsl:value-of select="/fhir:Bundle/fhir:entry/fhir:resource/fhir:Invoice[fhir:id/@value=$_rowId]/fhir:totalGross/fhir:currency/@value"/>                                </div>                            </div>                        </div>                        <div class="col-3">                            <div class="input-container">                                <label>Gesamtzuzahlung</label>                                <div class="text-input">                                    <xsl:value-of select="translate(/fhir:Bundle/fhir:entry/fhir:resource/fhir:Invoice[fhir:id/@value=$_rowId]/fhir:totalGross/fhir:extension[@url='http://fhir.abda.de/eRezeptAbgabedaten/StructureDefinition/DAV-EX-ERP-Gesamtzuzahlung']/fhir:valueMoney/fhir:value/@value, '.', ',')"/>                                    <xsl:text disable-output-escaping='yes'> </xsl:text>                                    <xsl:value-of select="/fhir:Bundle/fhir:entry/fhir:resource/fhir:Invoice[fhir:id/@value=$_rowId]/fhir:totalGross/fhir:extension[@url='http://fhir.abda.de/eRezeptAbgabedaten/StructureDefinition/DAV-EX-ERP-Gesamtzuzahlung']/fhir:valueMoney/fhir:currency/@value"/>                                </div>                            </div>                        </div>                    </div>                    <div class="row g-1">                        <div class="col-4">                            <div class="input-container">                                <label>abgebende Apotheke</label>                                <xsl:choose>                                    <xsl:when test="$anonymize='true'">                                        <div class="text-input">                                            <xsl:value-of select="'***'"/>                                        </div>                                    </xsl:when>                                    <xsl:otherwise>                                        <!-- normale Ausgabe -->                                        <textarea class="text-input" readonly="">                                            <xsl:value-of select="fhir:entry/fhir:resource/fhir:Organization/fhir:name/@value"/>                                        </textarea>                                    </xsl:otherwise>                                </xsl:choose>                            </div>                        </div>                        <div class="col-2">                            <div class="input-container">                                <label>IKNR</label>                                <div class="text-input">                                    <xsl:choose>                                        <xsl:when test="$anonymize='true'">                                            <xsl:value-of select="'***'"/>                                        </xsl:when>                                        <xsl:otherwise>                                            <!-- normale Ausgabe -->                                            <xsl:value-of select="fhir:entry/fhir:resource/fhir:Organization/fhir:identifier/fhir:value/@value"/>                                        </xsl:otherwise>                                    </xsl:choose>                                </div>                            </div>                        </div>                        <xsl:if test="fhir:entry/fhir:resource/fhir:MedicationDispense[fhir:type/fhir:coding/fhir:code/@value='Abgabeinformationen']/fhir:extension[@url='http://fhir.abda.de/eRezeptAbgabedaten/StructureDefinition/DAV-EX-ERP-Vertragskennzeichen']">                            <div class="col-6">                                <div class="input-container">                                    <label>Vertragskennzeichen</label>                                    <div class="text-input">                                        <xsl:value-of select="fhir:entry/fhir:resource/fhir:MedicationDispense[fhir:type/fhir:coding/fhir:code/@value='Abgabeinformationen']/fhir:extension[@url='http://fhir.abda.de/eRezeptAbgabedaten/StructureDefinition/DAV-EX-ERP-Vertragskennzeichen']/fhir:valueString/@value"/>                                    </div>                                </div>                            </div>                        </xsl:if>                    </div>                    <div class="row g-1">                        <div class="col-6">                            <div class="input-container">                                <label>Adresse</label>                                <xsl:choose>                                    <xsl:when test="$anonymize='true'">                                        <div class="text-input">                                            <xsl:value-of select="'***'"/>                                        </div>                                    </xsl:when>                                    <xsl:otherwise>                                        <!-- normale Ausgabe -->                                        <textarea class="text-input" readonly="">                                            <xsl:value-of select="fhir:entry/fhir:resource/fhir:Organization/fhir:address/fhir:line/@value"/>                                        </textarea>                                    </xsl:otherwise>                                </xsl:choose>                            </div>                        </div>                    </div>                    <div class="row g-1">                        <div class="col-1">                            <div class="input-container">                                <label>PLZ</label>                                <div class="text-input">                                    <xsl:choose>                                        <xsl:when test="$anonymize='true'">                                            <xsl:value-of select="'***'"/>                                        </xsl:when>                                        <xsl:otherwise>                                            <!-- normale Ausgabe -->                                            <xsl:value-of select="fhir:entry/fhir:resource/fhir:Organization/fhir:address/fhir:postalCode/@value"/>                                        </xsl:otherwise>                                    </xsl:choose>                                </div>                            </div>                        </div>                        <div class="col-4">                            <div class="input-container">                                <label>Ort</label>                                <xsl:choose>                                    <xsl:when test="$anonymize='true'">                                        <div class="text-input">                                            <xsl:value-of select="'***'"/>                                        </div>                                    </xsl:when>                                    <xsl:otherwise>                                        <!-- normale Ausgabe -->                                        <textarea class="text-input" readonly="">                                            <xsl:value-of select="fhir:entry/fhir:resource/fhir:Organization/fhir:address/fhir:city/@value"/>                                        </textarea>                                    </xsl:otherwise>                                </xsl:choose>                            </div>                        </div>                        <div class="col-1">                            <div class="input-container">                                <label>Land</label>                                <div class="text-input">                                    <xsl:choose>                                        <xsl:when test="$anonymize='true'">                                            <xsl:value-of select="'*'"/>                                        </xsl:when>                                        <xsl:otherwise>                                            <!-- normale Ausgabe -->                                            <xsl:value-of select="fhir:entry/fhir:resource/fhir:Organization/fhir:address/fhir:country/@value"/>                                        </xsl:otherwise>                                    </xsl:choose>                                </div>                            </div>                        </div>                    </div>                </div>            </div>            <!-- Dritter Container (100% des Platzes) -->            <div class="intern-container background-container-ges margin-left-min-2 margin-right-min-2 margin-top-min-5">                <div class="row g-1 width-100">                    <div class="col-12">                        <h4>Abrechnungszeilen</h4>                        <xsl:for-each select="/fhir:Bundle/fhir:entry/fhir:resource/fhir:Invoice[fhir:id/@value=$_rowId]/fhir:lineItem">                            <div class="row g-0">                                <div class="col-1">                                    <div class="input-container">                                        <label>Pos</label>                                        <!--xsl:number format="1 " /><xsl:value-of select="." /-->                                        <div class="text-input">                                            <xsl:value-of select="fhir:sequence/@value"/>                                        </div>                                    </div>                                </div>                                <div class="col-2" >                                    <div class="input-container">                                        <xsl:variable name="cs" select="fhir:chargeItemCodeableConcept/fhir