es select="fhir:extension/fhir:extension/fhir:extension[fhir:extension[@url='Gruppe']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value='2']" mode="table"/>                                                            <xsl:apply-templates select="fhir:extension/fhir:extension/fhir:extension[fhir:extension[@url='Gruppe']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value='3']" mode="table"/>                                                            <xsl:apply-templates select="fhir:extension/fhir:extension/fhir:extension[fhir:extension[@url='Gruppe']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value='4']" mode="table"/>                                                            <xsl:apply-templates select="fhir:extension/fhir:extension[fhir:extension[@url='Gruppe']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value='5']" mode="table"/>                                                            <xsl:apply-templates select="fhir:extension/fhir:extension[fhir:extension[@url='Gruppe']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value='6']" mode="table"/>                                                            <xsl:apply-templates select="fhir:extension/fhir:extension[fhir:extension[@url='Gruppe']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value='7']" mode="table"/>                                                            <xsl:apply-templates select="fhir:extension/fhir:extension[fhir:extension[@url='Gruppe']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value='8']" mode="table"/>                                                            <xsl:apply-templates select="fhir:extension/fhir:extension[fhir:extension[@url='Gruppe']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value='9']" mode="table"/>                                                            <xsl:apply-templates select="fhir:extension/fhir:extension[fhir:extension[@url='Gruppe']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value='10']" mode="table"/>       