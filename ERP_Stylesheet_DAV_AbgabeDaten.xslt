:extension[@url='Gruppe']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value='5']" mode="table"> <!-- Mehrkostenübernahme -->        <tr>            <td>Mehrkostenübernahme (Grp5)</td>            <td>                <xsl:variable name="schluessel" select="fhir:extension[@url='Schluessel']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value"/>                <xsl:choose>                    <xsl:when test="$schluessel='1'">ja, nach § 129 Abs. 4c SGB V</xsl:when>                    <xsl:when test="$schluessel='2'">ja, nach Rabattvertrag</xsl:when>                </xsl:choose>                <xsl:text disable-output-escaping='yes'> (</xsl:text>                <xsl:value-of select="$schluessel"/>                <xsl:text disable-output-escaping='yes'>)</xsl:text>            </td>        </tr>    </xsl:template>    <xsl:template match="fhir:extension[fhir:extension[@url='Gruppe']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value='6']" mode="table"> <!-- Wunscharzneimittel -->        <tr>            <td>Wunscharzneimittel (Grp6)</td>            <td>                <xsl:variable name="schluessel" select="fhir:extension[@url='Schluessel']/fhir:valueBoolean/@value"/>                <xsl:choose>                    <xsl:when test="$schluessel='true'">ja</xsl:when>                    <!--xsl:otherwise>nein</xsl:otherwise-->                </xsl:choose>            </td>        </tr>    </xsl:template>    <xsl:template match="fhir:extension[fhir:extension[@url='Gruppe']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value='7']" mode="table"> <!-- Wirkstoffverordnung -->        <tr>            <td>Wirkstoffverordnung (Grp7)</td>            <td>                <xsl:variable name="schluessel" select="fhir:extension[@url='Schluessel']/fhir:valueBoolean/@value"/>                <xsl:choose>                    <xsl:when test="$schluessel='true'">ja</xsl:when>                    <!--xsl:otherwise>nein</xsl:otherwise-->                </xsl:choose>            </td>        </tr>    </xsl:template>    <xsl:template match="fhir:extension[fhir:extension[@url='Gruppe']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value='8']" mode="table"> <!-- Ersatzverordnung -->        <tr>            <td>Ersatzverordnung (Grp8)</td>            <td>                <xsl:variable name="schluessel" select="fhir:extension[@url='Schluessel']/fhir:valueBoolean/@value"/>                <xsl:choose>                    <xsl:when test="$schluessel='true'">ja</xsl:when>                    <!--xsl:otherwise>nein</xsl:otherwise-->                </xsl:choose>            </td>        </tr>    </xsl:template>    <xsl:template match="fhir:extension[fhir:extension[@url='Gruppe']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value='9']" mode="table"> <!-- künstliche Befruchtung -->        <tr>            <td>Künstliche Befruchtung (Grp9)</td>            <td>                <xsl:variable name="schluessel" select="fhir:extension[@url='Schluessel']/fhir:valueBoolean/@value"/>                <xsl:choose>                    <xsl:when test="$schluessel='true'">ja, Abgabeangaben sind nicht zu beachten</xsl:when>                    <!--xsl:otherwise>nein</xsl:otherwise-->                </xsl:choose>            </td>        </tr>    </xsl:template>    <xsl:template match="fhir:extension[fhir:extension[@url='Gruppe']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value='10']" mode="table"> <!-- einzeln importierte Fertigarzneimittel -->        <tr>            <td>Einzeln importierte Fertigarzneimittel (Grp10)</td>            <td>                <xsl:variable name="schluessel" select="fhir:extension[@url='Schluessel']/fhir:valueBoolean/@value"/>                <xsl:choose>                    <xsl:when test="$schluessel='true'">ja, Abgabeangaben sind nicht zu beachten</xsl:when>                    <!--xsl:otherwise>nein</xsl:otherwise-->                </xsl:choose>            </td>        </tr>        <xsl:if test="fhir:extension[@url='DokumentationFreitext']">            <tr class="zusatz-doc-row">                <td colspan="2">                    <xsl:text disable-output-escaping='yes'>▸ Doku.: </xsl:text>                    <xsl:value-of select="fhir:extension[@url='DokumentationFreitext']/fhir:valueString/@value"/>                </td>            </tr>        </xsl:if>    </xsl:template>    <xsl:template match="fhir:extension[fhir:extension[@url='Gruppe']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value='11']" mode="table"> <!-- Abgabe im Notdienst -->        <tr>            <td>Abgabe im Notdienst (Grp11)</td>            <td>                <xsl:if test="fhir:extension[@url='DatumUhrzeit']"> <!-- TODO: eventuelle Umrechnung nach deutscher Zeit ?!? oder Anzeige Zeitverschiebung !!!-->                    <!--xsl:text disable-output-escaping='yes'>am </xsl:text-->                    <xsl:call-template name="formatDate">                        <xsl:with-param name="date" select="fhir:extension[@url='DatumUhrzeit']/fhir:valueDateTime/@value"/>                    </xsl:call-template>                    <xsl:text disable-output-escaping='yes'> </xsl:text>                    <!--xsl:text disable-output-escaping='yes'> um </xsl:text-->                    <xsl:call-template name="formatTime">                        <xsl:with-param name="date" select="fhir:extension[@url='DatumUhrzeit']/fhir:valueDateTime/@value"/>                    </xsl:call-template>                </xsl:if>            </td>        </tr>    </xsl:template>    <xsl:template match="fhir:extension[fhir:extension[@url='Gruppe']/fhir:valueCodeableConcept/fhir:coding/fhir:code/@value='12']" mode="table"> <!-- Zusätzliche Abgabeangaben -->        <tr>            <td>Zusätzliche Abgabeangaben (Grp12)</td>            <td>                <xsl:text disable-output-escaping='yes'> </xsl:text>    <!-- TODO: Spalte füllen ?!? -->            </td>        </tr>      